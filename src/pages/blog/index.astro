---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Tag from "../../components/Tag.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import GoogleAnalytics from "../../components/GoogleAnalytics.astro";

const posts = (await getCollection("blog")).sort(
  (b, a) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf()
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <GoogleAnalytics id="G-H58VPTB7C0" />
    <style>
      main {
        width: 960px;
      }
      .page-head {
        margin-bottom: var(--space-6);
      }
      .eyebrow {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        margin: 0 0 0.75rem;
      }
      .page-head h1 {
        font-size: clamp(2.2rem, 4vw, 3rem);
        margin: 0 0 0.5rem;
      }
      .page-head p {
        color: var(--ink-soft);
        font-size: 1.1rem;
        margin: 0;
        max-width: 40rem;
      }
      ul {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-6) var(--space-5);
        list-style: none;
        margin: 0;
        padding: 0;
      }
      .post a {
        display: block;
        text-decoration: none;
      }
      .thumb {
        overflow: hidden;
        border-radius: 12px;
        border: 1px solid var(--line);
      }
      .thumb img {
        display: block;
        width: 100%;
        aspect-ratio: 2 / 1;
        object-fit: cover;
        border-radius: 12px;
        transition: transform 0.3s ease;
      }
      .post a:hover .thumb img {
        transform: scale(1.03);
      }
      .chip {
        margin: 0.9rem 0 0.6rem;
      }
      .title {
        margin: 0 0 0.4rem;
        font-size: 1.35rem;
        color: var(--ink);
        line-height: 1.2;
        transition: color 0.2s ease;
      }
      .post a:hover .title {
        color: var(--accent);
      }
      .excerpt {
        margin: 0;
        color: var(--ink-soft);
        font-size: 0.95rem;
        line-height: 1.55;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
      }
      @media (max-width: 720px) {
        ul {
          grid-template-columns: 1fr;
          gap: var(--space-5);
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <header class="page-head">
        <p class="eyebrow">Writing</p>
        <h1>Notes on design & front-end craft</h1>
        <p>Practical write-ups from building and shipping product — design systems, accessibility, and the details in between.</p>
      </header>
      <section>
        <ul>
          {
            posts.map((post) => (
              <li class="post">
                <a href={`/blog/${post.id}/`}>
                  <div class="thumb">
                    <img
                      width={720}
                      height={360}
                      src={post.data.heroImage}
                      alt=""
                    />
                  </div>
                  {post.data.category && (
                    <div class="chip">
                      <Tag tag={post.data.category} />
                    </div>
                  )}
                  <h3 class="title">{post.data.title}</h3>
                  <p class="excerpt">{post.data.description}</p>
                </a>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
