---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Tag from "../../components/Tag.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import GoogleAnalytics from "../../components/GoogleAnalytics.astro";

const work = (await getCollection("work")).sort(
  (a, b) => a.data.order - b.data.order
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <GoogleAnalytics id="G-H58VPTB7C0" />
    <style>
      main {
        width: var(--page-max);
        display: flex;
        flex-direction: column;
        gap: var(--space-7);
      }
      .eyebrow {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        margin: 0 0 0.75rem;
      }
      .page-head h1 {
        font-size: clamp(2.2rem, 4vw, 3rem);
        margin: 0 0 0.5rem;
      }
      .page-head p {
        color: var(--ink-soft);
        font-size: 1.1rem;
        margin: 0;
        max-width: 44rem;
      }

      .work-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
        scroll-margin-top: 6rem;
      }
      .top {
        display: grid;
        grid-template-columns: minmax(0, 380px) 1fr;
        gap: var(--space-5);
        align-items: start;
      }
      .cover {
        width: 100%;
        height: auto;
        border-radius: 12px;
        border: 1px solid var(--line);
        box-shadow: 0 8px 24px rgba(28, 30, 27, 0.08);
      }
      .meta .date {
        margin: 0 0 0.5rem;
      }
      .company {
        margin: 0 0 0.9rem;
        font-size: 1.9rem;
        line-height: 1.1;
      }
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 1.1rem;
      }
      .description {
        color: var(--ink-soft);
        line-height: 1.6;
        font-size: 1rem;
        margin: 0;
      }

      .detail {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-6);
        border-top: 1px solid var(--line);
        padding-top: var(--space-4);
      }
      .col-head {
        font-family: var(--font-mono);
        font-size: 0.72rem;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: var(--ink-faint);
        margin: 0 0 0.9rem;
      }
      .col ul {
        margin: 0;
        padding: 0;
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
      }
      .col li {
        font-size: 0.98rem;
        line-height: 1.5;
        color: var(--ink-soft);
      }
      .col a {
        color: var(--accent);
        text-decoration: none;
      }
      .col a:hover {
        text-decoration: underline;
      }
      .soon {
        color: var(--ink-faint);
      }
      .soon .badge {
        font-family: var(--font-mono);
        font-size: 0.62rem;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        border: 1px solid var(--line);
        border-radius: 60px;
        padding: 0.1rem 0.5rem;
        margin-left: 0.4rem;
        color: var(--ink-faint);
        white-space: nowrap;
      }

      @media (max-width: 860px) {
        .top {
          grid-template-columns: 1fr;
        }
        .cover {
          max-width: 460px;
        }
      }
      @media (max-width: 620px) {
        .detail {
          grid-template-columns: 1fr;
          gap: var(--space-4);
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <header class="page-head">
        <p class="eyebrow">Work</p>
        <h1>A decade of designing products</h1>
        <p>Across education, climate tech, AI, and media — building intuitive tools and the design practices behind them.</p>
      </header>

      {
        work.map((item) => (
          <article class="work-item" id={item.id}>
            <div class="top">
              <img
                src={item.data.coverImage}
                alt={item.data.company}
                class="cover"
              />
              <div class="meta">
                <p class="eyebrow date">{item.data.workDates}</p>
                <h2 class="company">{item.data.company}</h2>
                <div class="tags">
                  {item.data.tags.map((tag) => (
                    <Tag tag={tag} />
                  ))}
                </div>
                <p class="description">{item.data.companyDescription}</p>
              </div>
            </div>
            <div class="detail">
              <div class="col">
                <p class="col-head">Key achievements</p>
                <ul>
                  {item.data.accomplishments.map((accomplishment) => (
                    <li>{accomplishment}</li>
                  ))}
                </ul>
              </div>
              <div class="col">
                <p class="col-head">Case studies</p>
                <ul>
                  {item.data.projectLinks.map((project) =>
                    project.projectLink === "#" ? (
                      <li class="soon">
                        {project.projectName.replace(" [coming soon]", "")}
                        <span class="badge">Coming soon</span>
                      </li>
                    ) : (
                      <li>
                        <a href={project.projectLink}>{project.projectName}</a>
                      </li>
                    )
                  )}
                </ul>
              </div>
            </div>
          </article>
        ))
      }
    </main>
    <Footer />
  </body>
</html>
