---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Tag from "../../components/Tag.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";
import GoogleAnalytics from "../../components/GoogleAnalytics.astro";

const work = (await getCollection("work")).sort(
  (a, b) => a.data.order - b.data.order
);

// Short pull-quote per role (highlighted line in the spread).
const quote: Record<string, string> = {
  "new-visions-for-public-schools":
    "Grew the design team and shipped features across every product vertical.",
  "upstream-tech":
    "Designed climate tools that help protect over 70 million acres worldwide.",
  "sage-talk": "Designed and built an AI support platform, end to end.",
  questex: "Led the redesign of a multi-brand CMS powering 15+ media sites.",
};
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <GoogleAnalytics id="G-H58VPTB7C0" />
    <style>
      main {
        width: var(--page-max);
        display: flex;
        flex-direction: column;
        gap: var(--space-7);
      }
      .eyebrow {
        font-family: var(--font-mono);
        font-size: 0.78rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--accent);
        margin: 0 0 0.75rem;
      }
      .page-head h1 {
        font-size: clamp(2.2rem, 4vw, 3rem);
        margin: 0 0 0.5rem;
      }
      .page-head > p {
        color: var(--ink-soft);
        font-size: 1.1rem;
        margin: 0;
        max-width: 44rem;
      }

      .spread {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-6);
        align-items: center;
        scroll-margin-top: 6rem;
      }
      .media {
        overflow: hidden;
        border-radius: 16px;
        border: 1px solid var(--line);
        box-shadow: 0 14px 40px rgba(0, 0, 0, 0.1);
      }
      .media img {
        display: block;
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        transition: transform 0.4s ease;
      }
      .media:hover img {
        transform: scale(1.04);
      }
      /* Alternate the image side */
      .spread:nth-child(even) .media {
        order: 2;
      }

      .company {
        margin: 0 0 1rem;
        font-size: clamp(1.9rem, 3vw, 2.6rem);
        line-height: 1.08;
      }
      .pull {
        font-family: var(--font-display);
        font-size: clamp(1.35rem, 2vw, 1.7rem);
        line-height: 1.3;
        color: var(--ink);
        margin: 0 0 1.25rem;
        max-width: 24ch;
      }
      .intro {
        color: var(--ink-soft);
        line-height: 1.6;
        margin: 0 0 1.25rem;
        max-width: 34rem;
      }
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
        margin-bottom: 1.5rem;
      }
      .cases {
        display: flex;
        flex-wrap: wrap;
        gap: 0.6rem 1.5rem;
        align-items: center;
      }
      .cases a {
        color: var(--accent);
        text-decoration: none;
        font-weight: 500;
      }
      .cases a:hover {
        text-decoration: underline;
      }
      .cases .soon {
        color: var(--ink-faint);
      }

      @media (max-width: 820px) {
        .spread {
          grid-template-columns: 1fr;
          gap: var(--space-4);
        }
        .spread:nth-child(even) .media {
          order: 0;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <header class="page-head">
        <p class="eyebrow">Work</p>
        <h1>A decade of designing products</h1>
        <p>Across education, climate tech, AI, and media, building the tools and the design practices behind them.</p>
      </header>

      {
        work.map((item) => (
          <article class="spread" id={item.id}>
            <div class="media">
              <img src={item.data.coverImage} alt={item.data.company} />
            </div>
            <div class="text">
              <p class="eyebrow">{item.data.workDates}</p>
              <h2 class="company">{item.data.company}</h2>
              {quote[item.id] && <p class="pull">{quote[item.id]}</p>}
              <p class="intro">{item.data.companyDescription}</p>
              <div class="tags">
                {item.data.tags.map((tag) => (
                  <Tag tag={tag} />
                ))}
              </div>
              <div class="cases">
                {item.data.projectLinks.map((p) =>
                  p.projectLink === "#" ? (
                    <span class="soon">
                      {p.projectName.replace(" [coming soon]", "")} (soon)
                    </span>
                  ) : (
                    <a href={p.projectLink}>{p.projectName} &rarr;</a>
                  )
                )}
              </div>
            </div>
          </article>
        ))
      }
    </main>
    <Footer />
  </body>
</html>
