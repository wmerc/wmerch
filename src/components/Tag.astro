---
const { tag } = Astro.props;
---

<div class="tag">
  {tag}
</div>
<style>
  .tag {
    display: inline-flex;
    border-radius: 60px;
    background: var(--surface-2);
    padding: 3px 12px;
    border: 1px solid var(--line);
    color: var(--ink-soft);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.4;
  }
</style>
