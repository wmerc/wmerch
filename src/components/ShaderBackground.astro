---
// Subtle animated WebGL gradient for the hero background.
// On-palette (paper + teal + logo cyan/green), gentle motion.
// Falls back to a plain paper background if WebGL is unavailable, and
// renders a single static frame when the user prefers reduced motion.
---

<canvas id="hero-shader" aria-hidden="true"></canvas>

<style>
  #hero-shader {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    z-index: 0;
  }
</style>

<script>
  const canvas = document.getElementById("hero-shader");
  if (canvas instanceof HTMLCanvasElement) {
    const gl = canvas.getContext("webgl", { antialias: true, alpha: false });
    const reduce = window.matchMedia(
      "(prefers-reduced-motion: reduce)",
    ).matches;

    if (!gl) {
      canvas.style.display = "none";
    } else {
      const g = gl;
      const vsrc = `attribute vec2 a_pos; void main(){ gl_Position = vec4(a_pos, 0.0, 1.0); }`;
      const fsrc = `
        precision mediump float;
        uniform vec2 u_res;
        uniform float u_time;
        uniform float u_dark;

        float hash(vec2 p){
          p = fract(p * vec2(123.34, 456.21));
          p += dot(p, p + 45.32);
          return fract(p.x * p.y);
        }
        float noise(vec2 p){
          vec2 i = floor(p);
          vec2 f = fract(p);
          vec2 u = f * f * (3.0 - 2.0 * f);
          float a = hash(i);
          float b = hash(i + vec2(1.0, 0.0));
          float c = hash(i + vec2(0.0, 1.0));
          float d = hash(i + vec2(1.0, 1.0));
          return mix(mix(a, b, u.x), mix(c, d, u.x), u.y);
        }
        float fbm(vec2 p){
          float v = 0.0;
          float a = 0.5;
          for (int i = 0; i < 5; i++){
            v += a * noise(p);
            p *= 2.0;
            a *= 0.5;
          }
          return v;
        }
        void main(){
          vec2 uv = gl_FragCoord.xy / u_res.xy;
          vec2 aspect = vec2(u_res.x / u_res.y, 1.0);
          vec2 p = uv * aspect * 2.2;
          float t = u_time * 0.03;

          vec2 q = vec2(fbm(p + t), fbm(p + vec2(5.2, 1.3) - t * 0.8));
          vec2 r = vec2(
            fbm(p + 1.7 * q + vec2(1.7, 9.2) + t * 0.4),
            fbm(p + 1.7 * q + vec2(8.3, 2.8) - t * 0.3)
          );
          float f = fbm(p + 1.5 * r);

          vec3 lightPaper = vec3(0.965, 0.957, 0.937);
          vec3 darkPaper  = vec3(0.102, 0.102, 0.090);
          vec3 paper = mix(lightPaper, darkPaper, u_dark);
          vec3 teal  = vec3(0.043, 0.416, 0.439);
          vec3 cyan  = vec3(0.455, 0.918, 0.953);
          vec3 green = vec3(0.839, 1.0, 0.569);
          float amp = mix(1.0, 0.55, u_dark);

          vec3 col = paper;
          col = mix(col, cyan,  smoothstep(0.15, 0.9, f) * 0.35 * amp);
          col = mix(col, teal,  smoothstep(0.35, 1.0, length(r)) * 0.26 * amp);
          col = mix(col, green, smoothstep(0.5, 1.0, q.x) * 0.16 * amp);
          col = mix(paper, col, 0.7);

          gl_FragColor = vec4(col, 1.0);
        }
      `;

      const compile = (type: number, src: string) => {
        const s = g.createShader(type)!;
        g.shaderSource(s, src);
        g.compileShader(s);
        return s;
      };

      const prog = g.createProgram()!;
      g.attachShader(prog, compile(g.VERTEX_SHADER, vsrc));
      g.attachShader(prog, compile(g.FRAGMENT_SHADER, fsrc));
      g.linkProgram(prog);
      g.useProgram(prog);

      const buf = g.createBuffer();
      g.bindBuffer(g.ARRAY_BUFFER, buf);
      g.bufferData(
        g.ARRAY_BUFFER,
        new Float32Array([-1, -1, 3, -1, -1, 3]),
        g.STATIC_DRAW,
      );
      const loc = g.getAttribLocation(prog, "a_pos");
      g.enableVertexAttribArray(loc);
      g.vertexAttribPointer(loc, 2, g.FLOAT, false, 0, 0);

      const uRes = g.getUniformLocation(prog, "u_res");
      const uTime = g.getUniformLocation(prog, "u_time");
      const uDark = g.getUniformLocation(prog, "u_dark");
      const dpr = Math.min(window.devicePixelRatio || 1, 1.5);

      const darkMq = window.matchMedia("(prefers-color-scheme: dark)");
      const isDark = () => {
        const t = document.documentElement.getAttribute("data-theme");
        if (t === "dark") return 1;
        if (t === "light") return 0;
        return darkMq.matches ? 1 : 0;
      };

      const resize = () => {
        const w = canvas.clientWidth;
        const h = canvas.clientHeight;
        canvas.width = Math.max(1, Math.floor(w * dpr));
        canvas.height = Math.max(1, Math.floor(h * dpr));
        g.viewport(0, 0, canvas.width, canvas.height);
      };
      resize();
      window.addEventListener("resize", resize);

      let running = true;
      const frame = (t: number) => {
        if (!running) return;
        g.uniform2f(uRes, canvas.width, canvas.height);
        g.uniform1f(uTime, t * 0.001);
        g.uniform1f(uDark, isDark());
        g.drawArrays(g.TRIANGLES, 0, 3);
        if (!reduce) requestAnimationFrame(frame);
      };
      requestAnimationFrame(frame);

      // Redraw the static frame if the theme changes while paused/reduced.
      const refresh = () => {
        if (reduce || !running) requestAnimationFrame(frame);
      };
      darkMq.addEventListener("change", refresh);
      new MutationObserver(refresh).observe(document.documentElement, {
        attributes: true,
        attributeFilter: ["data-theme"],
      });

      // Pause the loop when the hero scrolls out of view.
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) {
            if (!running && !reduce) {
              running = true;
              requestAnimationFrame(frame);
            }
          } else if (!reduce) {
            running = false;
          }
        });
      });
      io.observe(canvas);
    }
  }
</script>
