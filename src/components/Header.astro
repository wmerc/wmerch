---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../consts";
---

<header id="top">
  <nav>
    <a class="logo" href="/"
      ><img
        src="/wm-wordmark.svg"
        alt="Will Merchan Logo"
        class="wordmark"
      /></a
    >
    <div class="internal-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/work">Work</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
    </div>
  </nav>
</header>
<style>
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    margin: 0;
    padding: 0 var(--gutter);
    background: color-mix(in srgb, var(--paper) 88%, transparent);
    backdrop-filter: saturate(140%) blur(8px);
    border-bottom: 1px solid var(--line);
  }
  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: var(--page-max);
    margin: 0 auto;
  }
  .logo {
    display: flex;
    align-items: center;
  }
  .wordmark {
    border-radius: unset;
    width: 200px;
    display: block;
  }
  .internal-links {
    display: flex;
    gap: var(--space-1);
  }
  .internal-links a {
    position: relative;
    padding: 1.15rem 0.75rem;
    color: var(--ink);
    text-decoration: none;
    font-size: 0.95rem;
    transition: color 0.2s ease;
  }
  .internal-links a:hover {
    color: var(--accent);
  }
  .internal-links a.active {
    color: var(--accent);
  }
  .internal-links a.active::after {
    content: "";
    position: absolute;
    left: 0.75rem;
    right: 0.75rem;
    bottom: 0.85rem;
    height: 2px;
    background: var(--accent);
    border-radius: 2px;
  }

  @media screen and (max-width: 600px) {
    nav {
      flex-direction: column;
      padding: 0.75rem 0;
      gap: 0.5rem;
    }
    .wordmark {
      width: 180px;
    }
    .internal-links {
      justify-content: center;
      width: 100%;
    }
    .internal-links a {
      padding: 0.5rem 0.75rem;
    }
    .internal-links a.active::after {
      bottom: 0.25rem;
    }
  }
</style>
